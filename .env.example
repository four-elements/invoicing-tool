# ============================================================
# Datenbank
# ============================================================
DATABASE_URL="postgresql://invoicing:invoicing_dev@localhost:5432/invoicing"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Docker PostgreSQL (nur für docker-compose)
POSTGRES_USER=invoicing
POSTGRES_PASSWORD=invoicing_dev
POSTGRES_DB=invoicing
POSTGRES_PORT=5432

# ============================================================
# Better Auth
# ============================================================
# Mindestens 32 zufällige Zeichen – z.B.: openssl rand -base64 32
BETTER_AUTH_SECRET="ERSETZE_MICH_MIT_EINEM_SICHEREN_32_ZEICHEN_STRING"
BETTER_AUTH_URL="http://localhost:3000"

# ============================================================
# E-Mail (Resend)
# ============================================================
RESEND_API_KEY="re_DEIN_API_KEY"
RESEND_FROM_EMAIL="noreply@deine-domain.de"

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"                         # development | staging | production

# ============================================================
# Logging
# ============================================================
LOG_LEVEL="info"                              # trace | debug | info | warn | error

# ============================================================
# Admin-Consent: maximale Gültigkeitsdauer in Tagen
# ============================================================
ADMIN_CONSENT_MAX_DAYS=30
