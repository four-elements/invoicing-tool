{
  "name": "invoicing-tool",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "seed:system": "tsx packages/db/seeds/system.ts",
    "seed:admin": "tsx packages/db/seeds/admin.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
